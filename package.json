{
  "name": "beacon",
  "version": "0.2.0",
  "main": "./dist/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "rm -rf dist && tsc && tsc -p tsconfig.preload.json",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.beacon.lol",
    "productName": "Beacon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "data/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon.png",
    "extraResources": [
      "riotgames.pem"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "keywords": [],
  "author": "Ilia Goginashvili",
  "license": "MIT",
  "description": "Context-aware coaching overlay for League of Legends",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-store": "^11.0.2",
    "groq-sdk": "^1.1.2"
  }
}
